        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cảm ơn lớn đến [jailbreak.party](https://github.com/jailbreakdotparty/dirtyZero)!\\nLƯU Ý: Nhiều Tweak hiện không hoạt động.\\nVấn đề này có thể sẽ được khắc phục trong bản cập nhật tới."
          }
        }
      }
    },
    "Font Overwrite is only available in VFS or Hybrid mode.\\n(Settings -> Method -> VFS/Hybrid)": {
      "extractionState": "manual",
      "localizations": {
