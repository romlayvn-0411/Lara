        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Big thanks [jailbreak.party](https://github.com/jailbreakdotparty/dirtyZero)!\\nNOTE: A lot of Tweaks currently dont work.\\nThis will probably be fixed in a future update."
