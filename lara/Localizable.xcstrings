{
  "sourceLanguage": "en",
  "strings": {
    "./ipsw extract --kernel [drag your ipsw here]": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "./ipsw extract --kernel [drag your ipsw here]"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "./ipsw extract --kernel [kéo file ipsw của bạn vào đây]"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "./ipsw extract --kernel [将您的 ipsw 拖放到此处]"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "./ipsw extract --kernel [اسحب ملف ipsw هنا]"
          }
        }
      }
    },
    "1. Download the IPSW tool for your device.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Download the IPSW tool for your device."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Tải công cụ IPSW cho thiết bị của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 为您的设备下载 IPSW 工具。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "1. قم بتنزيل أداة IPSW لجهازك."
          }
        }
      }
    },
    "1. Switch to hybrid mode in settings \n2. Escape the Sandbox \n3. Initialise VFS\n4. Try again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Switch to hybrid mode in settings \n2. Escape the Sandbox \n3. Initialise VFS\n4. Try again."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Chuyển sang chế độ Hybrid trong cài đặt \n2. Thoát Sandbox \n3. Khởi tạo VFS\n4. Thử lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 在设置中切换到混合模式 \n2. 逃逸沙盒 \n3. 初始化 VFS\n4. 重试。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "1. قم بالتبديل إلى الوضع الهجين في الإعدادات \n2. الهروب من Sandbox \n3. تهيئة VFS \n4. حاول مرة أخرى."
          }
        }
      }
    },
    "2. Extract the archive.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Extract the archive."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Giải nén tệp lưu trữ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "2. 解压缩文件。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "2. استخراج الأرشيف."
          }
        }
      }
    },
    "3. Open Terminal.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "3. Open Terminal."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "3. Mở Terminal."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "3. 打开终端 (Terminal)。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "3. افتح الوحدة الطرفية (Terminal)."
          }
        }
      }
    },
    "4. Navigate to the extracted folder:": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "4. Navigate to the extracted folder:"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "4. Di chuyển đến thư mục đã giải nén:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "4. 导航到解压后的文件夹："
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "4. انتقل إلى المجلد المستخرج:"
          }
        }
      }
    },
    "5. Extract the kernel:": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "5. Extract the kernel:"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "5. Trích xuất kernel:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "5. 提取内核："
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "5. استخراج النواة (Kernel):"
          }
        }
      }
    },
    "6. Get the kernelcache file.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "6. Get the kernelcache file."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "6. Lấy file kernelcache."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "6. 获取 kernelcache 文件。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "6. احصل على ملف kernelcache."
          }
        }
      }
    },
    "7. Transfer the kernelcache to your iCloud or iPhone.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "7. Transfer the kernelcache to your iCloud or iPhone."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "7. Chuyển file kernelcache sang iCloud hoặc iPhone của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "7. 将 kernelcache 传输到您的 iCloud 或 iPhone。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "7. انقل kernelcache إلى iCloud أو iPhone الخاص بك."
          }
        }
      }
    },
    "8. Tap the button above and select the kernelcache, for example kernelcache.release.iPhone14,3.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "8. Tap the button above and select the kernelcache, for example kernelcache.release.iPhone14,3."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "8. Nhấn vào nút bên trên và chọn file kernelcache, ví dụ: kernelcache.release.iPhone14,3."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "8. 点击上方按钮并选择 kernelcache，例如 kernelcache.release.iPhone14,3。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "8. اضغط على الزر أعلاه وحدد kernelcache، على سبيل المثال kernelcache.release.iPhone14,3."
          }
        }
      }
    },
